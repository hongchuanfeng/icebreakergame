<%- include('partials/header', { 
    pageTitle: typeof t !== 'undefined' ? t('game.title', { gameName: gameName }) : (pageTitle || (gameName + ' - Ice Breaker Games')),
    metaDescription: typeof t !== 'undefined' ? t('game.description', { gameName: gameName, categoryName: gameCategory || '' }) : (gameDescription || ('玩 ' + gameName + ' - 免费在线HTML5游戏')),
    metaKeywords: gameKeywords || (gameName + ', ice breaker games'),
    canonicalUrl: typeof localeUrl !== 'undefined' ? localeUrl('/game?name=' + encodeURIComponent(gameName)) : (canonicalUrl || ('https://www.icebreakgame.com/game?name=' + encodeURIComponent(gameName))),
    searchQuery: ''
}) %>

<!-- 主内容区 -->
<div class="main-content">
    <!-- 内容区（全宽显示） -->
    <div class="content-area" style="width: 100%;">
        <!-- 游戏控制栏 -->
        <div class="game-control-bar">
            <div class="game-control-left">
                <h1 class="game-detail-title-inline"><%- game.name %></h1>
                <% if (gameCategory) { %>
                    <div class="game-detail-category-inline">
                        <span class="nav-icon"><%= getCategoryIcon(gameCategory) %></span>
                        <a href="<%= typeof localeUrl !== 'undefined' ? localeUrl('/category?categoryId=' + (typeof categoryId !== 'undefined' ? categoryId : '')) : '/category?categoryId=' + (typeof categoryId !== 'undefined' ? categoryId : '') %>" style="color: rgba(255, 255, 255, 0.8); text-decoration: none;">
                            <%= gameCategory %>
                        </a>
                    </div>
                <% } %>
            </div>
            <div class="game-control-right">
                <% if (gameCategory) { %>
                    <a href="<%= typeof localeUrl !== 'undefined' ? localeUrl('/category?categoryId=' + (typeof categoryId !== 'undefined' ? categoryId : '')) : '/category?categoryId=' + (typeof categoryId !== 'undefined' ? categoryId : '') %>" class="game-control-btn">
                        ← <%= typeof t !== 'undefined' ? t('game.backToCategory') : '返回分类' %>
                    </a>
                <% } %>
                <a href="<%= typeof localeUrl !== 'undefined' ? localeUrl('/') : '/' %>" class="game-control-btn">
                    ← <%= typeof t !== 'undefined' ? t('game.backToHome') : '返回首页' %>
                </a>
                <button id="fullscreenBtn" class="game-control-btn fullscreen-btn">
                    ⛶ <%= typeof t !== 'undefined' ? t('game.fullscreen') : '全屏' %>
                </button>
            </div>
        </div>

        <!-- 游戏iframe容器 -->
        <div class="game-iframe-container" id="gameContainer">
            <% if (game.link) { %>
                <iframe 
                    id="gameIframe" 
                    src="<%= game.link %>" 
                    frameborder="0" 
                    allowfullscreen
                    style="width: 100%; height: 100%; border: none;">
                </iframe>
            <% } else { %>
                <div class="game-iframe-placeholder">
                    <div style="text-align: center; color: rgba(255, 255, 255, 0.7); padding: 3rem;">
                        <h2 style="margin-bottom: 1rem; font-size: 2rem;">🎮</h2>
                        <p style="font-size: 1.2rem; margin-bottom: 0.5rem;"><%= typeof t !== 'undefined' ? t('game.noLink') : '该游戏暂无链接' %></p>
                        <p style="font-size: 0.9rem;">
                            <% if (game.href) { %>
                                <a href="<%= game.href %>" target="_blank" style="color: rgba(102, 126, 234, 0.9); text-decoration: underline;">
                                    <%= typeof t !== 'undefined' ? t('game.viewDetailPage') : '查看游戏详情页' %>
                                </a>
                            <% } %>
                        </p>
                    </div>
                </div>
            <% } %>
        </div>
        
        <!-- 游戏详情信息 -->
        <div class="game-detail-section">

            <!-- 游戏头部信息（折叠显示） -->
            <div class="game-info-header">
                <div class="game-info-header-content">
                    <% if (game.icon) { %>
                        <img src="<%= game.icon %>" alt="<%= game.name %>" class="game-info-image" onerror="this.style.display='none';">
                    <% } %>
                    <div class="game-info-text">
                        <h2 class="game-info-title"><%- game.name %></h2>
                        <% if (gameCategory) { %>
                            <div class="game-info-category">
                                <span class="nav-icon"><%= getCategoryIcon(gameCategory) %></span>
                                <a href="<%= typeof localeUrl !== 'undefined' ? localeUrl('/category?categoryId=' + (typeof categoryId !== 'undefined' ? categoryId : '')) : '/category?categoryId=' + (typeof categoryId !== 'undefined' ? categoryId : '') %>" style="color: rgba(102, 126, 234, 0.9); text-decoration: none;">
                                    <%= gameCategory %>
                                </a>
                            </div>
                        <% } %>
                    </div>
                </div>
            </div>

            <!-- 游戏描述 -->
            <% if (game.detail) { %>
                <div class="game-detail-content">
                    <h2 class="game-detail-section-title"><%= typeof t !== 'undefined' ? t('game.gameIntroduction') : '游戏介绍' %></h2>
                    <div id="game-detail-text" class="game-detail-text" data-game-id="<%= typeof gameId !== 'undefined' ? gameId : game.id %>" data-category-id="<%= typeof categoryId !== 'undefined' ? categoryId : '' %>" data-locale="<%= typeof locale !== 'undefined' ? locale : 'zh-CN' %>">
                        <% 
                            // 格式化描述文本，将换行转换为段落
                            const detailLines = game.detail.split('\n').filter(line => line.trim());
                            let inParagraph = false;
                            let skipNext = false;
                            
                            detailLines.forEach((line, index) => {
                                const trimmedLine = line.trim();
                                
                                // 跳过一些元数据行和分隔符
                                if (trimmedLine.includes('Games»') || 
                                    trimmedLine === 'Share' ||
                                    trimmedLine.includes('Developer') && !trimmedLine.includes(':') ||
                                    trimmedLine.includes('Rating') && !trimmedLine.includes(':') ||
                                    trimmedLine.includes('Released') && !trimmedLine.includes(':') ||
                                    trimmedLine.includes('Technology') && !trimmedLine.includes(':') ||
                                    trimmedLine.includes('Platform') && !trimmedLine.includes(':') ||
                                    trimmedLine.includes('Wiki pages') ||
                                    trimmedLine.match(/^[0-9]+$/) ||  // 纯数字
                                    trimmedLine.length < 5) {
                                    return;
                                }
                                
                                // 如果是标题行（短且可能是标题，且没有标点符号）
                                if (trimmedLine.length < 60 && 
                                    !trimmedLine.includes('.') && 
                                    !trimmedLine.includes(',') &&
                                    !trimmedLine.includes('?') &&
                                    !trimmedLine.includes('!') &&
                                    trimmedLine.length > 10 &&
                                    index < 15) {
                                    if (inParagraph) {
                                        inParagraph = false;
                                        %>
                                        </p>
                                        <%
                                    }
                                    // 检查是否是常见的标题格式
                                    if (trimmedLine.match(/^[A-Z][a-z]+ [A-Z][a-z]+/) || 
                                        trimmedLine.match(/^[A-Z][a-z]+ [a-z]+ [A-Z]/) ||
                                        trimmedLine.includes('How to') ||
                                        trimmedLine.includes('Features') ||
                                        trimmedLine.includes('Controls') ||
                                        trimmedLine.includes('FAQ')) {
                                        %>
                                        <h3 class="game-detail-subtitle"><%= trimmedLine %></h3>
                                        <%
                                    }
                                    return;
                                }
                                
                                // 如果是段落内容（长度合理且有意义的文本）
                                if (trimmedLine.length > 15) {
                                    // 转义HTML特殊字符（除了我们允许的格式）
                                    const escapedLine = trimmedLine
                                        .replace(/&/g, '&amp;')
                                        .replace(/</g, '&lt;')
                                        .replace(/>/g, '&gt;')
                                        .replace(/&lt;strong&gt;/g, '<strong>')
                                        .replace(/&lt;\/strong&gt;/g, '</strong>');
                                    
                                    if (!inParagraph) {
                                        inParagraph = true;
                                        %>
                                        <p>
                                        <%
                                    } else {
                                        %>
                                        <br><br>
                                        <%
                                    }
                                    %>
                                    <%- escapedLine %>
                                    <%
                                }
                            });
                            if (inParagraph) {
                                %>
                                </p>
                                <%
                            }
                        %>
                    </div>
                </div>
            <% } %>

            <!-- 游戏特性 -->
            <div class="game-features">
                <h2 class="game-detail-section-title"><%= typeof t !== 'undefined' ? t('game.gameFeatures') : '游戏特性' %></h2>
                <ul class="game-features-list">
                    <li>✅ <%= typeof t !== 'undefined' ? t('game.features.free') : '免费在线游戏，无需下载' %></li>
                    <li>✅ <%= typeof t !== 'undefined' ? t('game.features.crossPlatform') : '支持PC和移动端' %></li>
                    <li>✅ <%= typeof t !== 'undefined' ? t('game.features.html5') : 'HTML5技术，即开即玩' %></li>
                    <% if (gameCategory) { %>
                        <li>✅ <%= typeof t !== 'undefined' ? t('game.features.category', { category: gameCategory }) : ('属于' + gameCategory + '分类') %></li>
                    <% } %>
                </ul>
            </div>

            <!-- 相关游戏推荐 -->
            <% if (gameCategory) { %>
                <div class="game-related">
                    <h2 class="game-detail-section-title"><%= typeof t !== 'undefined' ? t('game.relatedGames') : '相关游戏推荐' %></h2>
                    <div style="text-align: center; margin-top: 1rem;">
                        <a href="<%= typeof localeUrl !== 'undefined' ? localeUrl('/category?categoryId=' + (typeof categoryId !== 'undefined' ? categoryId : '')) : '/category?categoryId=' + (typeof categoryId !== 'undefined' ? categoryId : '') %>" class="more-btn">
                            <%= typeof t !== 'undefined' ? t('game.viewAllInCategory', { category: gameCategory }) : ('查看 ' + gameCategory + ' 分类下的所有游戏 →') %>
                        </a>
                    </div>
                </div>
            <% } %>

            <!-- 游戏评价 -->
            <div class="game-reviews" style="margin-top: 2rem; padding: 1.5rem; background: rgba(255,255,255,0.05); border-radius: 16px;">
                <h2 class="game-detail-section-title">
                    <%= typeof t !== 'undefined' ? t('game.reviews') : '游戏评价' %>
                    <% if (typeof averageRating !== 'undefined' && averageRating > 0) { %>
                        <span style="font-size: 1rem; color: #ffd700; margin-left: 0.5rem;">
                            ★ <%= averageRating %>
                        </span>
                    <% } %>
                </h2>
                
                <!-- 评价表单（仅已登录用户可见） -->
                <% if (typeof isLoggedIn !== 'undefined' && isLoggedIn && typeof userEmail !== 'undefined' && userEmail) { %>
                    <div class="review-form" style="margin-bottom: 1.5rem; padding: 1rem; background: rgba(255,255,255,0.08); border-radius: 12px;">
                        <h3 style="color: rgba(255,255,255,0.9); margin-bottom: 1rem;"><%= typeof t !== 'undefined' ? t('game.writeReview') : '发表评价' %></h3>
                        <div style="margin-bottom: 1rem;">
                            <label style="color: rgba(255,255,255,0.8); display: block; margin-bottom: 0.5rem;"><%= typeof t !== 'undefined' ? t('game.rating') : '评分' %>:</label>
                            <div class="rating-stars" id="ratingStars" style="display: flex; gap: 0.5rem;">
                                <% for (let i = 1; i <= 5; i++) { %>
                                    <span class="star" data-rating="<%= i %>" style="font-size: 1.5rem; cursor: pointer; color: #666;">★</span>
                                <% } %>
                            </div>
                            <input type="hidden" id="selectedRating" name="rating" value="0">
                        </div>
                        <div style="margin-bottom: 1rem;">
                            <label style="color: rgba(255,255,255,0.8); display: block; margin-bottom: 0.5rem;"><%= typeof t !== 'undefined' ? t('game.comment') : '评论' %>:</label>
                            <textarea id="reviewComment" rows="3" style="width: 100%; padding: 0.75rem; border: 2px solid rgba(255,255,255,0.2); border-radius: 8px; background: rgba(255,255,255,0.1); color: #fff; font-size: 0.95rem; resize: vertical;" placeholder="<%= typeof t !== 'undefined' ? t('game.commentPlaceholder') : '写下你的评价...' %>"></textarea>
                        </div>
                        <button id="submitReviewBtn" style="background: linear-gradient(135deg, #667eea, #764ba2); color: white; border: none; padding: 0.75rem 1.5rem; border-radius: 8px; cursor: pointer; font-weight: 600; transition: transform 0.2s;">
                            <%= typeof t !== 'undefined' ? t('game.submitReview') : '提交评价' %>
                        </button>
                        <div id="reviewMessage" style="margin-top: 0.5rem; font-size: 0.9rem;"></div>
                    </div>
                <% } else { %>
                    <p style="color: rgba(255,255,255,0.7); margin-bottom: 1rem;">
                        <%= typeof t !== 'undefined' ? t('game.loginToReview') : '登录后可发表评价' %>
                        <a href="<%= typeof localeUrl !== 'undefined' ? localeUrl('/login') : '/login' %>" style="color: #667eea;"><%= typeof t !== 'undefined' ? t('auth.loginButton') : '登录' %></a>
                    </p>
                <% } %>
                
                <!-- 评价列表 -->
                <div id="reviewsList" class="reviews-list">
                    <% if (typeof gameReviews !== 'undefined' && gameReviews.length > 0) { %>
                        <% gameReviews.forEach(function(review) { %>
                            <div class="review-item" style="padding: 1rem; background: rgba(255,255,255,0.05); border-radius: 8px; margin-bottom: 1rem;">
                                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.5rem;">
                                    <span style="color: #ffd700; font-size: 1rem;">
                                        <% for (let i = 1; i <= 5; i++) { %>
                                            <%= i <= review.rating ? '★' : '☆' %>
                                        <% } %>
                                    </span>
                                    <span style="color: rgba(255,255,255,0.5); font-size: 0.85rem;">
                                        <%= new Date(review.created_at).toLocaleDateString() %>
                                    </span>
                                </div>
                                <% if (review.comment) { %>
                                    <p style="color: rgba(255,255,255,0.85); margin: 0.5rem 0;"><%= review.comment %></p>
                                <% } %>
                                <div style="color: rgba(255,255,255,0.5); font-size: 0.8rem;">
                                    <%= review.user_email %>
                                </div>
                            </div>
                        <% }); %>
                    <% } else { %>
                        <p id="noReviews" style="color: rgba(255,255,255,0.6); text-align: center; padding: 1rem;">
                            <%= typeof t !== 'undefined' ? t('game.noReviews') : '暂无评价，快来发表第一个评价吧！' %>
                        </p>
                    <% } %>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .star:hover,
    .star.active {
        color: #ffd700 !important;
    }
</style>

<script>
    // 评价相关功能
    const gameId = '<%= typeof gameId !== "undefined" ? gameId : "" %>';
    const userEmail = '<%= typeof userEmail !== "undefined" ? userEmail : "" %>';
    const isLoggedIn = <%= typeof isLoggedIn !== "undefined" && isLoggedIn %>;
    
    // 评分星星交互
    const stars = document.querySelectorAll('.star');
    const selectedRatingInput = document.getElementById('selectedRating');
    
    if (stars.length > 0) {
        stars.forEach(star => {
            star.addEventListener('mouseenter', function() {
                const rating = parseInt(this.dataset.rating);
                updateStars(rating);
            });
            
            star.addEventListener('click', function() {
                const rating = parseInt(this.dataset.rating);
                selectedRatingInput.value = rating;
                updateStars(rating);
            });
        });
        
        document.getElementById('ratingStars').addEventListener('mouseleave', function() {
            const currentRating = parseInt(selectedRatingInput.value) || 0;
            updateStars(currentRating);
        });
        
        function updateStars(rating) {
            stars.forEach((star, index) => {
                star.style.color = index < rating ? '#ffd700' : '#666';
            });
        }
    }
    
    // 提交评价
    const submitBtn = document.getElementById('submitReviewBtn');
    if (submitBtn) {
        submitBtn.addEventListener('click', async function() {
            const rating = parseInt(document.getElementById('selectedRating').value);
            const comment = document.getElementById('reviewComment').value.trim();
            const messageEl = document.getElementById('reviewMessage');
            
            if (!rating || rating < 1 || rating > 5) {
                messageEl.innerHTML = '<span style="color: #e74c3c;"><%= typeof t !== "undefined" ? t("game.ratingRequired") : "请选择评分" %></span>';
                return;
            }
            
            if (!userEmail) {
                messageEl.innerHTML = '<span style="color: #e74c3c;"><%= typeof t !== "undefined" ? t("game.loginRequired") : "请先登录" %></span>';
                return;
            }
            
            submitBtn.disabled = true;
            submitBtn.textContent = '<%= typeof t !== "undefined" ? t("game.submitting") : "提交中..." %>';
            
            try {
                const response = await fetch('/api/game-reviews', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        gameId: gameId,
                        rating: rating,
                        comment: comment,
                        userEmail: userEmail
                    })
                });
                
                const result = await response.json();
                
                if (result.success) {
                    messageEl.innerHTML = '<span style="color: #2ecc71;"><%= typeof t !== "undefined" ? t("game.reviewSuccess") : "评价提交成功！" %></span>';
                    document.getElementById('selectedRating').value = 0;
                    document.getElementById('reviewComment').value = '';
                    updateStars(0);
                    
                    // 刷新评价列表
                    loadReviews();
                } else {
                    messageEl.innerHTML = '<span style="color: #e74c3c;">' + (result.error || '<%= typeof t !== "undefined" ? t("game.reviewError") : "提交失败，请重试" %>') + '</span>';
                }
            } catch (err) {
                messageEl.innerHTML = '<span style="color: #e74c3c;"><%= typeof t !== "undefined" ? t("game.reviewError") : "提交失败，请重试" %></span>';
            }
            
            submitBtn.disabled = false;
            submitBtn.textContent = '<%= typeof t !== "undefined" ? t("game.submitReview") : "提交评价" %>';
        });
    }
    
    // 加载评价列表
    async function loadReviews() {
        try {
            const response = await fetch('/api/game-reviews?gameId=' + gameId);
            const result = await response.json();
            
            if (result.reviews && result.reviews.length > 0) {
                const reviewsList = document.getElementById('reviewsList');
                const noReviews = document.getElementById('noReviews');
                if (noReviews) noReviews.remove();
                
                let html = '';
                result.reviews.forEach(review => {
                    let stars = '';
                    for (let i = 1; i <= 5; i++) {
                        stars += i <= review.rating ? '★' : '☆';
                    }
                    
                    html += '<div class="review-item" style="padding: 1rem; background: rgba(255,255,255,0.05); border-radius: 8px; margin-bottom: 1rem;">';
                    html += '<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.5rem;">';
                    html += '<span style="color: #ffd700; font-size: 1rem;">' + stars + '</span>';
                    html += '<span style="color: rgba(255,255,255,0.5); font-size: 0.85rem;">' + new Date(review.created_at).toLocaleDateString() + '</span>';
                    html += '</div>';
                    if (review.comment) {
                        html += '<p style="color: rgba(255,255,255,0.85); margin: 0.5rem 0;">' + review.comment + '</p>';
                    }
                    html += '<div style="color: rgba(255,255,255,0.5); font-size: 0.8rem;">' + review.user_email + '</div>';
                    html += '</div>';
                });
                
                reviewsList.innerHTML = html;
                
                // 更新平均评分
                const ratingEl = document.querySelector('.game-reviews .game-detail-section-title span');
                if (ratingEl && result.averageRating) {
                    ratingEl.textContent = '★ ' + result.averageRating;
                }
            }
        } catch (err) {
            console.error('Error loading reviews:', err);
        }
    }
</script>

<script>
    // 全屏功能
    document.addEventListener('DOMContentLoaded', function() {
        const fullscreenBtn = document.getElementById('fullscreenBtn');
        const gameContainer = document.getElementById('gameContainer');
        const gameIframe = document.getElementById('gameIframe');
        
        if (!fullscreenBtn || !gameContainer) return;
        
        const fullscreenText = '<%= typeof t !== "undefined" ? t("game.fullscreen") : "全屏" %>';
        const exitFullscreenText = '<%= typeof t !== "undefined" ? t("game.exitFullscreen") : "退出全屏" %>';
        
        function toggleFullscreen() {
            if (!document.fullscreenElement && !document.webkitFullscreenElement && !document.mozFullScreenElement && !document.msFullscreenElement) {
                // 进入全屏
                if (gameContainer.requestFullscreen) {
                    gameContainer.requestFullscreen();
                } else if (gameContainer.webkitRequestFullscreen) {
                    gameContainer.webkitRequestFullscreen();
                } else if (gameContainer.mozRequestFullScreen) {
                    gameContainer.mozRequestFullScreen();
                } else if (gameContainer.msRequestFullscreen) {
                    gameContainer.msRequestFullscreen();
                }
            } else {
                // 退出全屏
                if (document.exitFullscreen) {
                    document.exitFullscreen();
                } else if (document.webkitExitFullscreen) {
                    document.webkitExitFullscreen();
                } else if (document.mozCancelFullScreen) {
                    document.mozCancelFullScreen();
                } else if (document.msExitFullscreen) {
                    document.msExitFullscreen();
                }
            }
        }
        
        fullscreenBtn.addEventListener('click', toggleFullscreen);
        
        // 监听全屏状态变化
        function handleFullscreenChange() {
            if (document.fullscreenElement || document.webkitFullscreenElement || document.mozFullScreenElement || document.msFullscreenElement) {
                fullscreenBtn.textContent = '❌ ' + exitFullscreenText;
                fullscreenBtn.classList.add('active');
            } else {
                fullscreenBtn.textContent = '⛶ ' + fullscreenText;
                fullscreenBtn.classList.remove('active');
            }
        }
        
        document.addEventListener('fullscreenchange', handleFullscreenChange);
        document.addEventListener('webkitfullscreenchange', handleFullscreenChange);
        document.addEventListener('mozfullscreenchange', handleFullscreenChange);
        document.addEventListener('MSFullscreenChange', handleFullscreenChange);
        
        // 键盘快捷键：F11 全屏，ESC 退出（浏览器默认处理）
    });
</script>

<%- include('partials/footer') %>
