<%- include('partials/static-header', { 
  pageTitle: typeof t !== 'undefined' ? t('auth.forgotTitle') : '忘记密码',
  metaDescription: typeof t !== 'undefined' ? t('auth.forgotDescription') : '通过邮箱重置 Ice Breaker Games 登录密码',
  metaKeywords: 'forgot password, 重置密码, Ice Breaker Games',
  canonicalUrl: typeof localeUrl !== 'undefined' ? localeUrl('/forgot-password') : 'https://www.icebreakgame.com/forgot-password'
}) %>

<main>
  <div class="container">
    <section class="content-section" style="max-width: 480px; margin: 3rem auto;">
      <h1 class="page-title" style="font-size: 2rem; text-align: center; margin-bottom: 1.5rem;">
        <%= typeof t !== 'undefined' ? t('auth.forgotTitle') : '忘记密码' %>
      </h1>

      <% if (typeof errorMessage !== 'undefined' && errorMessage) { %>
        <div class="form-message error" style="display:block;">
          <%= errorMessage %>
        </div>
      <% } %>

      <% if (typeof successMessage !== 'undefined' && successMessage) { %>
        <div class="form-message success" style="display:block;">
          <%= successMessage %>
        </div>
      <% } %>

      <form method="POST" action="/forgot-password" style="margin-top: 1.5rem;">
        <div class="form-group">
          <label for="email"><%= typeof t !== 'undefined' ? t('auth.email') : '邮箱' %></label>
          <input 
            type="email" 
            id="email" 
            name="email" 
            required 
            placeholder="<%= typeof t !== 'undefined' ? t('auth.emailPlaceholder') : '请输入注册时使用的邮箱' %>"
            value="<%= typeof formData !== 'undefined' && formData.email ? formData.email : '' %>"
          />
        </div>

        <div class="form-group">
          <label for="password"><%= typeof t !== 'undefined' ? t('auth.newPassword') : '新密码' %></label>
          <input 
            type="password" 
            id="password" 
            name="password" 
            required 
            minlength="6"
            placeholder="<%= typeof t !== 'undefined' ? t('auth.passwordPlaceholder') : '请输入新密码（至少6位）' %>"
          />
        </div>

        <div class="form-group">
          <label for="confirmPassword"><%= typeof t !== 'undefined' ? t('auth.confirmPassword') : '确认密码' %></label>
          <input 
            type="password" 
            id="confirmPassword" 
            name="confirmPassword" 
            required 
            minlength="6"
            placeholder="<%= typeof t !== 'undefined' ? t('auth.confirmPasswordPlaceholder') : '请再次输入新密码' %>"
          />
        </div>

        <button type="submit" class="submit-btn">
          <%= typeof t !== 'undefined' ? t('auth.resetPassword') : '修改密码' %>
        </button>
      </form>

      <p style="margin-top: 0.5rem; font-size: 0.9rem; color: rgba(255,255,255,0.7); text-align:center;">
        <a href="<%= typeof localeUrl !== 'undefined' ? localeUrl('/login') : '/login' %>" style="color: #8ea5ff; text-decoration:none;">
          <%= typeof t !== 'undefined' ? t('auth.backToLogin') : '返回登录' %>
        </a>
      </p>
    </section>
  </div>
</main>

<footer>
  <div class="container">
    <div class="footer-bottom">
      © 2024 Ice Breaker Games. All rights reserved.
    </div>
  </div>
</footer>

<script>
  (function() {
    const form = document.querySelector('form');
    if (!form) return;
    form.addEventListener('submit', function(e) {
      const password = document.getElementById('password');
      const confirmPassword = document.getElementById('confirmPassword');
      const btn = form.querySelector('button[type="submit"]');
      
      if (password && confirmPassword && password.value !== confirmPassword.value) {
        e.preventDefault();
        alert('<%= typeof t !== "undefined" ? t("auth.errorPasswordMismatch") : "两次输入的密码不一致" %>');
        return;
      }
      
      if (btn) {
        btn.disabled = true;
        btn.textContent = '<%= typeof t !== "undefined" ? t("auth.processing") : "处理中..." %>';
      }
    });
  })();
</script>


