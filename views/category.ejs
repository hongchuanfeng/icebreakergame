<%- include('partials/header', { 
    pageTitle: typeof t !== 'undefined' ? t('category.title', { categoryName: category }) : (category + ' - Ice Breaker Games'),
    metaDescription: typeof t !== 'undefined' ? t('category.description', { categoryName: category, totalGames: totalGames }) : ('浏览 ' + category + ' 分类下的所有游戏，免费在线HTML5游戏平台'),
    metaKeywords: categoryKeywords || (category + ', ice breaker games'),
    canonicalUrl: typeof localeUrl !== 'undefined' ? localeUrl('/category/' + encodeURIComponent(category) + (searchQuery ? '?q=' + encodeURIComponent(searchQuery) : '')) : ('https://www.icebreakgame.com/category/' + encodeURIComponent(category) + (searchQuery ? '?q=' + encodeURIComponent(searchQuery) : '')),
    searchQuery: searchQuery || ''
}) %>

<!-- 主内容区 -->
<div class="main-content">
    <!-- 内容区（全宽显示） -->
    <div class="content-area" style="width: 100%;">
        <div class="category-section">
            <div class="category-header">
                <div style="flex: 1;">
                    <h2 class="category-title"><%= category %></h2>
                    <div style="margin-top: 0.5rem; color: rgba(255, 255, 255, 0.7); font-size: 0.9rem;">
                        <% if (searchQuery) { %>
                            <%= typeof t !== 'undefined' ? t('category.searchFound', { query: searchQuery, count: totalGames }) : ('搜索 "' + searchQuery + '" 找到 ' + totalGames + ' 款游戏') %>
                        <% } else { %>
                            <%= typeof t !== 'undefined' ? t('category.gamesFound', { count: totalGames }) : ('共 ' + totalGames + ' 款游戏') %>
                        <% } %>
                        <% if (totalPages > 1) { %>
                            <%= typeof t !== 'undefined' ? t('category.pageInfo', { current: currentPage, total: totalPages }) : ('（第 ' + currentPage + ' / ' + totalPages + ' 页）') %>
                        <% } %>
                    </div>
                </div>
                <div style="display: flex; gap: 1rem; align-items: center; flex-wrap: wrap;">
                    <!-- 分类搜索框 -->
                    <div class="category-search-box" style="position: relative; min-width: 320px; flex: 1;">
                        <form method="GET" action="<%= typeof localeUrl !== 'undefined' ? localeUrl('/category/' + encodeURIComponent(typeof originalCategory !== 'undefined' ? originalCategory : category)) : '/category/' + encodeURIComponent(typeof originalCategory !== 'undefined' ? originalCategory : category) %>" style="position: relative;">
                            <input type="text" name="q" class="category-search-input category-search-input-field" placeholder="🔍 <%= typeof t !== 'undefined' ? t('category.searchPlaceholder') : '在本分类中搜索...' %>" value="<%= searchQuery || '' %>" style="width: 100%; padding: 12px 50px 12px 16px; border: 2px solid rgba(255, 255, 255, 0.2); border-radius: 12px; font-size: 14px; background: rgba(255, 255, 255, 0.15); backdrop-filter: blur(10px); color: #ffffff; transition: all 0.3s ease;">
                            <button type="submit" style="position: absolute; right: 8px; top: 50%; transform: translateY(-50%); background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); border: none; padding: 8px 20px; border-radius: 8px; color: white; cursor: pointer; font-size: 14px; font-weight: 600;"><%= typeof t !== 'undefined' ? t('category.searchButton') : '搜索' %></button>
                        </form>
                        <% if (searchQuery) { %>
                            <a href="<%= typeof localeUrl !== 'undefined' ? localeUrl('/category/' + encodeURIComponent(typeof originalCategory !== 'undefined' ? originalCategory : category)) : '/category/' + encodeURIComponent(typeof originalCategory !== 'undefined' ? originalCategory : category) %>" style="display: block; margin-top: 0.5rem; color: rgba(255, 255, 255, 0.7); text-decoration: none; font-size: 0.85rem; text-align: right;"><%= typeof t !== 'undefined' ? t('category.clearSearch') : '清除搜索' %></a>
                        <% } %>
                    </div>
                    <a href="<%= typeof localeUrl !== 'undefined' ? localeUrl('/') : '/' %>" class="more-btn"><%= typeof t !== 'undefined' ? t('category.backToHome') : '返回首页' %></a>
                </div>
            </div>
            
            <% if (games.length > 0) { %>
                <div class="games-grid">
                    <% games.forEach(game => { %>
                        <a href="<%= typeof localeUrl !== 'undefined' ? localeUrl('/game?categoryId=' + (typeof categoryId !== 'undefined' ? categoryId : '') + '&gameId=' + (game.id || '')) : '/game?categoryId=' + (typeof categoryId !== 'undefined' ? categoryId : '') + '&gameId=' + (game.id || '') %>"
                           class="game-card">
                            <div class="game-card-image-wrapper">
                                <% if (game.icon) { %>
                                    <img src="<%= game.icon %>" alt="<%= game.name %>" class="game-card-image" onerror="this.onerror=null; this.parentElement.innerHTML='<div class=&quot;game-card-image&quot;>🎮</div>'">
                                <% } else { %>
                                    <div class="game-card-image">🎮</div>
                                <% } %>
                                <% const playCount = playCounts && playCounts[String(game.id)] ? playCounts[String(game.id)] : 0; %>
                                <% if (playCount > 0) { %>
                                    <div class="play-count-badge">
                                        <span class="play-icon">▶</span><%= playCount %>
                                    </div>
                                <% } %>
                            </div>
                            <div class="game-card-info">
                                <div class="game-card-name"><%- game.name %></div>
                            </div>
                        </a>
                    <% }); %>
                </div>
                
                <!-- 分页导航 -->
                <% if (totalPages > 1) { %>
                    <div class="pagination-container">
                        <div class="pagination">
                            <% const urlCategoryId = typeof categoryId !== 'undefined' ? categoryId : ''; %>
                            <% if (currentPage > 1) { %>
                                <a href="<%= typeof localeUrl !== 'undefined' ? localeUrl('/category?categoryId=' + urlCategoryId + '&page=' + (currentPage - 1) + (searchQuery ? '&q=' + encodeURIComponent(searchQuery) : '')) : '/category?categoryId=' + urlCategoryId + '&page=' + (currentPage - 1) + (searchQuery ? '&q=' + encodeURIComponent(searchQuery) : '') %>" class="pagination-btn"><%= typeof t !== 'undefined' ? t('category.previousPage') : '上一页' %></a>
                            <% } else { %>
                                <span class="pagination-btn disabled"><%= typeof t !== 'undefined' ? t('category.previousPage') : '上一页' %></span>
                            <% } %>
                            
                            <% 
                                // 显示页码
                                let startPage = Math.max(1, currentPage - 2);
                                let endPage = Math.min(totalPages, currentPage + 2);
                                
                                if (startPage > 1) { %>
                                    <a href="<%= typeof localeUrl !== 'undefined' ? localeUrl('/category?categoryId=' + urlCategoryId + '&page=1' + (searchQuery ? '&q=' + encodeURIComponent(searchQuery) : '')) : '/category?categoryId=' + urlCategoryId + '&page=1' + (searchQuery ? '&q=' + encodeURIComponent(searchQuery) : '') %>" class="pagination-number">1</a>
                                    <% if (startPage > 2) { %>
                                        <span class="pagination-ellipsis">...</span>
                                    <% } %>
                                <% }
                                
                                for (let i = startPage; i <= endPage; i++) { %>
                                    <% if (i === currentPage) { %>
                                        <span class="pagination-number active"><%= i %></span>
                                    <% } else { %>
                                        <a href="<%= typeof localeUrl !== 'undefined' ? localeUrl('/category?categoryId=' + urlCategoryId + '&page=' + i + (searchQuery ? '&q=' + encodeURIComponent(searchQuery) : '')) : '/category?categoryId=' + urlCategoryId + '&page=' + i + (searchQuery ? '&q=' + encodeURIComponent(searchQuery) : '') %>" class="pagination-number"><%= i %></a>
                                    <% } %>
                                <% }
                                
                                if (endPage < totalPages) { %>
                                    <% if (endPage < totalPages - 1) { %>
                                        <span class="pagination-ellipsis">...</span>
                                    <% } %>
                                    <a href="<%= typeof localeUrl !== 'undefined' ? localeUrl('/category?categoryId=' + urlCategoryId + '&page=' + totalPages + (searchQuery ? '&q=' + encodeURIComponent(searchQuery) : '')) : '/category?categoryId=' + urlCategoryId + '&page=' + totalPages + (searchQuery ? '&q=' + encodeURIComponent(searchQuery) : '') %>" class="pagination-number"><%= totalPages %></a>
                                <% } %>
                                
                            <% if (currentPage < totalPages) { %>
                                <a href="<%= typeof localeUrl !== 'undefined' ? localeUrl('/category?categoryId=' + urlCategoryId + '&page=' + (currentPage + 1) + (searchQuery ? '&q=' + encodeURIComponent(searchQuery) : '')) : '/category?categoryId=' + urlCategoryId + '&page=' + (currentPage + 1) + (searchQuery ? '&q=' + encodeURIComponent(searchQuery) : '') %>" class="pagination-btn"><%= typeof t !== 'undefined' ? t('category.nextPage') : '下一页' %></a>
                            <% } else { %>
                                <span class="pagination-btn disabled"><%= typeof t !== 'undefined' ? t('category.nextPage') : '下一页' %></span>
                            <% } %>
                        </div>
                    </div>
                <% } %>
            <% } else { %>
                <div style="text-align: center; color: rgba(255, 255, 255, 0.7); padding: 3rem;">
                    <h3 style="margin-bottom: 1rem;"><%= typeof t !== 'undefined' ? t('category.noGames') : '未找到相关游戏' %></h3>
                    <p><%= typeof t !== 'undefined' ? t('category.tryOtherKeywords') : '请尝试其他搜索关键词，或' %><a href="<%= typeof localeUrl !== 'undefined' ? localeUrl('/category/' + encodeURIComponent(typeof originalCategory !== 'undefined' ? originalCategory : category)) : '/category/' + encodeURIComponent(typeof originalCategory !== 'undefined' ? originalCategory : category) %>" style="color: rgba(102, 126, 234, 0.8); text-decoration: underline;"><%= typeof t !== 'undefined' ? t('category.viewAllGames') : '查看所有游戏' %></a></p>
                </div>
            <% } %>
        </div>
    </div>
</div>

<%- include('partials/footer') %>
