<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="<%= metaDescription || 'Ice Breaker Games - 免费在线HTML5游戏平台，提供丰富多样的游戏体验。无需下载，即开即玩，随时随地享受游戏乐趣。' %>">
    <meta name="keywords" content="<%= metaKeywords || 'ice breaker games, multiplayer games, online games, fun games, party games, HTML5 games, 免费游戏, 在线游戏' %>">
    <meta name="robots" content="index, follow">
    <title><%= pageTitle || 'Ice Breaker Games - 免费在线HTML5游戏平台' %></title>
    <link rel="canonical" href="<%= canonicalUrl || 'https://www.icebreakgame.com/' %>">
    
    <!-- Open Graph (Facebook & X) -->
    <meta property="og:title" content="<%= pageTitle || 'Ice Breaker Games' %>">
    <meta property="og:description" content="<%= metaDescription || '免费在线HTML5游戏平台，提供丰富多样的游戏体验。无需下载，即开即玩。' %>">
    <meta property="og:image" content="<%= ogImage || 'https://www.icebreakgame.com/og-image.png' %>">
    <meta property="og:url" content="<%= canonicalUrl || 'https://www.icebreakgame.com/' %>">
    <meta property="og:type" content="<%= ogType || 'website' %>">
    <meta property="og:site_name" content="Ice Breaker Games">
    
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="<%= pageTitle || 'Ice Breaker Games' %>">
    <meta name="twitter:description" content="<%= metaDescription || '免费在线HTML5游戏平台，提供丰富多样的游戏体验。无需下载，即开即玩。' %>">
    <meta name="twitter:image" content="<%= ogImage || 'https://www.icebreakgame.com/og-image.png' %>">
    
    <link rel="icon" type="image/x-icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🎮</text></svg>">
    
    <%- include('styles') %>
    
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-HT40C8VPYX"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-HT40C8VPYX');
    </script>
    
    <!-- Google AdSense -->
    <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-7274710287377352"
         crossorigin="anonymous"></script>
</head>
<body>
    <!-- 顶部搜索栏（带logo） -->
    <div class="top-header">
        <div class="header-content">
            <a href="<%= typeof localeUrl !== 'undefined' ? localeUrl('/') : '/' %>" class="logo-section">
                <span class="logo-icon">🎮</span>
                <span>Ice Breaker Games</span>
            </a>
            <div class="search-box">
                <span class="search-icon">🔍</span>
                <form method="GET" action="<%= typeof localeUrl !== 'undefined' ? localeUrl('/search') : '/search' %>" style="display: inline-block; width: 100%;">
                    <input type="text" name="q" id="searchInput" class="search-input" placeholder="<%= typeof t !== 'undefined' ? t('common.searchPlaceholder') : '搜索游戏...' %>" value="<%= searchQuery || '' %>">
                </form>
            </div>
                <!-- 语言切换器 + 登录按钮 -->
                <div class="language-switcher">
                    <% if (typeof supportedLocales !== 'undefined' && supportedLocales) { %>
                        <% supportedLocales.forEach(loc => { %>
                            <a href="/set-locale/<%= loc %>" 
                               class="lang-btn <%= (typeof locale !== 'undefined' && locale === loc) ? 'active' : '' %>"
                               data-locale="<%= loc %>">
                                <%= loc === 'zh-CN' ? '中文' : loc.toUpperCase() %>
                            </a>
                        <% }); %>
                    <% } else { %>
                        <!-- 默认显示中英文切换 -->
                        <a href="/set-locale/en" class="lang-btn">EN</a>
                        <a href="/set-locale/zh-CN" class="lang-btn">中文</a>
                    <% } %>

                    <% if (typeof isLoggedIn !== 'undefined' && isLoggedIn && typeof userEmail !== 'undefined' && userEmail) { %>
                        <!-- 已登录：显示邮箱和退出按钮 -->
                        <a href="<%= typeof localeUrl !== 'undefined' ? localeUrl('/profile') : '/profile' %>" 
                           style="margin-left: 0.5rem; color: rgba(255,255,255,0.9); font-size: 0.85rem; max-width: 150px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; text-decoration: none; padding: 4px 8px; border-radius: 4px; transition: background 0.2s;"
                           title="<%= userEmail %>">
                            <%= userEmail %>
                        </a>
                        <a href="/logout" class="lang-btn" style="margin-left: 0.5rem; background: rgba(231, 76, 60, 0.8);">
                            <%= typeof t !== 'undefined' ? t('auth.logout') : '退出' %>
                        </a>
                    <% } else { %>
                        <!-- 未登录：显示登录按钮 -->
                        <a href="<%= typeof localeUrl !== 'undefined' ? localeUrl('/login') : '/login' %>" 
                           class="lang-btn"
                           style="margin-left: 0.5rem;">
                            <%= typeof t !== 'undefined' ? t('auth.loginButton') : '登录' %>
                        </a>
                    <% } %>
                </div>
        </div>
    </div>
